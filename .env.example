# =============================================================================
# Supabase
# =============================================================================
# Crear el proyecto en https://supabase.com → Settings → API Keys
# Supabase ahora usa "publishable" (browser) y "secret" (server) en vez de
# los legacy anon/service_role. Funcionan igual con el SDK; podés pegar
# cualquiera de los dos formatos en estas variables.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
# SOLO para scripts del lado server (migraciones, N8N). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# =============================================================================
# N8N (fase 2)
# =============================================================================
N8N_WEBHOOK_URL=""
N8N_API_KEY=""

# =============================================================================
# Apify (fase 2)
# =============================================================================
APIFY_API_TOKEN=""

# =============================================================================
# Google Sheets (data de scraping RRSS existente, fase 2)
# =============================================================================
GOOGLE_SHEETS_SOCIAL_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
