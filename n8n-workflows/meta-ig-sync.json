    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Combina IG Classic + Engagement + Followers en meta_ig_daily rows.\nconst igId = 'REPLACE_IG_USER_ID';\nconst out = new Map();\nfor (const item of items) {\n  const input = item.json || {};\n  for (const m of input.data || []) {\n    const name = m.name;\n    // total_value (engagement/follower_demographics) vs values (classic)\n    if (m.total_value && typeof m.total_value.value === 'number') {\n      // Engagement metrics con metric_type=total_value pero period=day\n      // devuelven una serie en `values`. Si llega total_value sin breakdown,\n      // es un único punto agregado.\n      const fecha = new Date().toISOString().slice(0,10);\n      const row = out.get(fecha) ?? { fecha, ig_user_id: igId };\n      row[name] = Number(m.total_value.value);\n      out.set(fecha, row);\n      continue;\n    }\n    for (const v of m.values || []) {\n      const fecha = (v.end_time || '').slice(0, 10);\n      if (!fecha) continue;\n      const row = out.get(fecha) ?? { fecha, ig_user_id: igId };\n      const val = typeof v.value === 'number' ? v.value : 0;\n      row[name] = val;\n      out.set(fecha, row);\n    }\n  }\n}\n// Mapeo a columnas finales (defaults a 0 / null).\nconst rows = [];\nfor (const row of out.values()) {\n  rows.push({ json: {\n    fecha: row.fecha,\n    ig_user_id: row.ig_user_id,\n    reach: row.reach || 0,\n    impressions: row.impressions || 0,\n    follower_count: row.follower_count ?? null,\n    profile_views: row.profile_views || 0,\n    website_clicks: row.website_clicks || 0,\n    email_contacts: row.email_contacts || 0,\n    phone_call_clicks: row.phone_call_clicks || 0,\n    likes: row.likes || 0,\n    comments: row.comments || 0,\n    saves: row.saves || 0,\n    shares: row.shares || 0,\n    total_interactions: row.total_interactions || 0,\n    accounts_engaged: row.accounts_engaged ?? null,\n  }});\n}\nreturn rows;"
      },
      "id": "code-norm-ig-daily",
      "name": "Normalize IG Daily",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-540, 0]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Normaliza IG media (posts).\nconst igId = 'REPLACE_IG_USER_ID';\nconst out = [];\nconst posts = items[0]?.json?.data || [];\nfor (const p of posts) {\n  const insightsArr = p.insights?.data || [];\n  const m = {};\n  for (const i of insightsArr) {\n    if (Array.isArray(i.values) && i.values.length > 0) {\n      const v = i.values[0].value;\n      m[i.name] = typeof v === 'number' ? v : 0;\n    }\n  }\n  out.push({ json: {\n    platform: 'instagram',\n    post_id: p.id,\n    cuenta_id: igId,\n    fecha_post: p.timestamp || new Date().toISOString(),\n    permalink: p.permalink || null,\n    message: p.caption || null,\n    media_type: p.media_type || null,\n    thumbnail_url: p.thumbnail_url || p.media_url || null,\n    impressions: m.impressions || 0,\n    reach: m.reach || 0,\n    engagement: m.total_interactions || 0,\n    reactions: 0,\n    likes: typeof p.like_count === 'number' ? p.like_count : 0,\n    comments: typeof p.comments_count === 'number' ? p.comments_count : 0,\n    shares: m.shares || 0,\n    saved: m.saved || 0,\n    video_views: m.video_views || 0,\n    clicks: 0,\n    raw: p,\n  }});\n}\nreturn out;"
      },
      "id": "code-norm-ig-media",
      "name": "Normalize IG Media",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-540, 400]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Normaliza demographics breakdowns (follower / engaged x age_gender, country, city).\n// El nodo recibe MULTIPLES items concatenados; cada item es la response\n// de un breakdown distinto. Se distingue por:\n//   - metric name: follower_demographics o engaged_audience_demographics\n//   - dimension del breakdown (lo inferimos de dimension_keys)\nconst igId = 'REPLACE_IG_USER_ID';\nconst fecha = new Date().toISOString().slice(0, 10);\nconst out = [];\n\nconst TYPE_MAP = {\n  follower_demographics: 'follower',\n  engaged_audience_demographics: 'engaged',\n  reached_audience_demographics: 'reached',\n};\n\nfor (const item of items) {\n  const data = item.json?.data || [];\n  for (const m of data) {\n    const audienceType = TYPE_MAP[m.name];\n    if (!audienceType) continue;\n    const breakdowns = m.total_value?.breakdowns || [];\n    for (const b of breakdowns) {\n      const dims = (b.dimension_keys || []).map(String);\n      const dimension = dims.length === 1 ? dims[0] :\n        (dims.includes('age') && dims.includes('gender')) ? 'age_gender' : dims.join('_');\n      for (const r of (b.results || [])) {\n        const category = (r.dimension_values || []).join(' / ') || '(unknown)';\n        const value = typeof r.value === 'number' ? r.value : 0;\n        out.push({ json: {\n          fecha,\n          ig_user_id: igId,\n          audience_type: audienceType,\n          dimension,\n          category,\n          value,\n        }});\n      }\n    }\n  }\n}\nreturn out;"
      },
      "id": "code-norm-demographics",
      "name": "Normalize Demographics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-540, 780]
    },
