      "parameters": {
        "language": "javaScript",
        "jsCode": "// Ventana de 30 días terminando ayer (UTC).\nconst toDate = new Date();\ntoDate.setUTCDate(toDate.getUTCDate() - 1);\nconst fromDate = new Date(toDate);\nfromDate.setUTCDate(fromDate.getUTCDate() - 29);\nconst toIso = toDate.toISOString().slice(0, 10);\nconst fromIso = fromDate.toISOString().slice(0, 10);\nconst sinceUnix = Math.floor(fromDate.getTime() / 1000);\nconst untilUnix = Math.floor((toDate.getTime() + 86400000) / 1000);\nconst snapshot = toIso;\nreturn [{ json: { from: fromIso, to: toIso, since: sinceUnix, until: untilUnix, snapshot } }];"
      },
